# GenLayer Bradbury Testnet Configuration
# Copy this to .env.local and fill in your values

# Your deployed ClauseGuard contract address (from GenLayer Studio)
NEXT_PUBLIC_CONTRACT_ADDRESS=0xYOUR_CONTRACT_ADDRESS_HERE

# GenLayer RPC endpoint (Bradbury testnet)
NEXT_PUBLIC_GENLAYER_RPC_URL=https://rpc.bradbury.genlayer.com
